PORT=4000
NODE_ENV=development
# One origin, or comma-separated: https://you.github.io,https://app.vercel.app
# If unset in production, API allows any browser Origin (reflect) so login works from GitHub Pages/Vercel.
FRONTEND_URL=http://localhost:3000
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/air_sensor
JWT_ACCESS_SECRET=replace-with-long-random-secret
JWT_REFRESH_SECRET=replace-with-long-random-secret
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=30d
GOOGLE_SHEET_ID=
GOOGLE_SERVICE_ACCOUNT_EMAIL=
GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# OpenAQ v3 (optional — Analysis “reference” line for PM2.5). Never commit real keys.
# https://docs.openaq.org/using-the-api/api-key
OPENAQ_API_KEY=
