# Frontend (Create React App) environment. Copy to .env and fill in.
# Only REACT_APP_* vars are exposed to the browser bundle.

# Backend API base. Defaults are baked into src/api/http.js (localhost in dev, Render in prod);
# set this only to override. Must end at the host or /api (the code appends /api if missing).
REACT_APP_API_BASE_URL=

# Firebase Web app config (Project settings → Your apps → Web app).
# These are not secrets, but keep them in .env so each environment can point at its own project.
REACT_APP_FIREBASE_API_KEY=
REACT_APP_FIREBASE_AUTH_DOMAIN=
REACT_APP_FIREBASE_PROJECT_ID=
REACT_APP_FIREBASE_STORAGE_BUCKET=
REACT_APP_FIREBASE_MESSAGING_SENDER_ID=
REACT_APP_FIREBASE_APP_ID=
